generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USER & AUTHENTICATION
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile             UserProfile?
  activities          Activity[]
  goals               Goal[]
  insights            Insight[]
  streak              Streak?
  badges              UserBadge[]
  points              PointTransaction[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  dashboardCaches     DashboardCache[]

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model UserProfile {
  id                 String              @id @default(uuid())
  userId             String              @unique @map("user_id")
  country            String?
  householdSize      Int?                @default(1) @map("household_size")
  primaryTransport   String?             @map("primary_transport")
  dietaryPreference  String?             @map("dietary_preference")
  homeEnergySource   String?             @map("home_energy_source")
  avgCommuteKm       Float?              @map("avg_commute_km")
  measurementSystem  String              @default("metric") @map("measurement_system")
  onboardingComplete Boolean             @default(false) @map("onboarding_complete")
  leaderboardOptIn   Boolean             @default(false) @map("leaderboard_opt_in")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  tokenHash   String   @map("token_hash")
  tokenFamily String   @map("token_family")
  isRevoked   Boolean  @default(false) @map("is_revoked")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@index([tokenFamily])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  isUsed    Boolean  @default(false) @map("is_used")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// ACTIVITY & CARBON TRACKING
// ─────────────────────────────────────────────

model ActivityCategory {
  id           String               @id @default(uuid())
  type         String               // ActivityCategoryType
  name         String
  slug         String               @unique
  icon         String
  description  String?
  sortOrder    Int                  @default(0) @map("sort_order")
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")

  activities      Activity[]
  emissionFactors EmissionFactor[]
  goals           Goal[]

  @@index([type])
  @@index([slug])
  @@map("activity_categories")
}

model EmissionFactor {
  id           String          @id @default(uuid())
  categoryId   String          @map("category_id")
  subcategory  String
  displayName  String          @map("display_name")
  unit         String          // MeasurementUnit
  factorKgCo2e Float           @map("factor_kg_co2e")
  source       String
  region       String          @default("global")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  category ActivityCategory @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, subcategory, region])
  @@index([categoryId])
  @@index([subcategory])
  @@map("emission_factors")
}

model Activity {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  categoryId   String   @map("category_id")
  subcategory  String
  displayName  String   @map("display_name")
  value        Float
  unit         String   // MeasurementUnit
  emissionKg   Float    @map("emission_kg")
  notes        String?
  loggedAt     DateTime @map("logged_at")
  isQuickLog   Boolean  @default(false) @map("is_quick_log")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ActivityCategory @relation(fields: [categoryId], references: [id])

  @@index([userId, loggedAt])
  @@index([userId, categoryId])
  @@index([userId, loggedAt, categoryId])
  @@index([loggedAt])
  @@map("activities")
}

// ─────────────────────────────────────────────
// DASHBOARD & CACHING
// ─────────────────────────────────────────────

model DashboardCache {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  cacheKey   String   @map("cache_key")
  data       String   // Stringified JSON for SQLite compat
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cacheKey])
  @@index([userId, cacheKey])
  @@index([expiresAt])
  @@map("dashboard_caches")
}

// ─────────────────────────────────────────────
// AI INSIGHTS
// ─────────────────────────────────────────────

model Insight {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  type        String        // InsightType
  source      String        // InsightSource
  content     String        // Stringified JSON for SQLite compat
  promptHash  String?       @map("prompt_hash")
  periodStart DateTime?     @map("period_start")
  periodEnd   DateTime?     @map("period_end")
  expiresAt   DateTime      @map("expires_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("insights")
}

// ─────────────────────────────────────────────
// GOALS
// ─────────────────────────────────────────────

model GoalPreset {
  id           String               @id @default(uuid())
  name         String
  description  String
  type         String               // GoalType
  targetValue  Float                @map("target_value")
  categoryType String?              // ActivityCategoryType?
  durationDays Int                  @map("duration_days")
  difficulty   String               @default("medium")
  icon         String
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")

  goals Goal[]

  @@map("goal_presets")
}

model Goal {
  id            String               @id @default(uuid())
  userId        String               @map("user_id")
  presetId      String?              @map("preset_id")
  categoryId    String?              @map("category_id")
  name          String
  description   String?
  type          String               // GoalType
  targetValue   Float                @map("target_value")
  currentValue  Float                @default(0) @map("current_value")
  baselineValue Float?               @map("baseline_value")
  status        String               @default("ACTIVE") // GoalStatus
  startDate     DateTime             @map("start_date")
  endDate       DateTime             @map("end_date")
  completedAt   DateTime?            @map("completed_at")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  preset   GoalPreset?       @relation(fields: [presetId], references: [id])
  category ActivityCategory? @relation(fields: [categoryId], references: [id])

  @@index([userId, status])
  @@index([userId, endDate])
  @@index([status, endDate])
  @@map("goals")
}

// ─────────────────────────────────────────────
// GAMIFICATION
// ─────────────────────────────────────────────

model Streak {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  currentStreak  Int      @default(0) @map("current_streak")
  longestStreak  Int      @default(0) @map("longest_streak")
  lastActivityAt DateTime? @map("last_activity_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model Badge {
  id          String        @id @default(uuid())
  slug        String        @unique
  name        String
  description String
  icon        String
  category    String        // BadgeCategory
  threshold   Int
  points      Int
  sortOrder   Int           @default(0) @map("sort_order")
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")

  userBadges UserBadge[]

  @@index([category])
  @@map("badges")
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  badgeId    String   @map("badge_id")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model PointTransaction {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  points      Int
  source      String      // PointSource
  referenceId String?     @map("reference_id")
  description String
  createdAt   DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, source])
  @@map("point_transactions")
}

// ─────────────────────────────────────────────
// AUDIT & SECURITY
// ─────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?     @map("user_id")
  action    String      // AuditAction
  ipAddress String?     @map("ip_address")
  userAgent String?     @map("user_agent")
  metadata  String?     // Stringified JSON
  createdAt DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, action])
  @@index([createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}
