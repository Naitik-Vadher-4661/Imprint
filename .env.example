# ─── App ───
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Database ───
DATABASE_URL=postgresql://imprint:password@localhost:5432/imprint

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── JWT ───
JWT_SECRET=super_secret_dev_key_change_me_in_prod
JWT_REFRESH_SECRET=super_secret_refresh_dev_key_change_me_in_prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── AI Providers ───
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ─── ClimateIQ ───
CLIMATEIQ_API_KEY=your_climateiq_api_key_here

# ─── LocationIQ ───
LOCATIONIQ_API_KEY=your_locationiq_api_key_here

# ─── PostHog Analytics ───
POSTHOG_API_KEY=your_posthog_api_key_here
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_client_key_here
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Email (Password Reset) ───
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=user
SMTP_PASS=pass
SMTP_FROM=noreply@imprint.app

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ───
LOG_LEVEL=debug
